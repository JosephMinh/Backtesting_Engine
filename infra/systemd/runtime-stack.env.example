# Non-secret environment for the Backtesting Engine one-host stack.
# Keep runtime values in the external mount-path variable, not in this file.
BACKTESTING_ENGINE_REPO=/home/ubuntu/ntm_Dev/Backtesting_Engine
BACKTESTING_ENGINE_STACK_MODE=non_economic_smoke
BACKTESTING_ENGINE_BROKER_GATEWAY_ENDPOINT=127.0.0.1:4002
BACKTESTING_ENGINE_POSTGRES_DSN=postgresql://backtesting_engine@127.0.0.1/backtesting_engine
BACKTESTING_ENGINE_ARTIFACT_ROOT=/var/lib/backtesting-engine/artifacts
BACKTESTING_ENGINE_LOG_ROOT=/var/log/backtesting-engine
BACKTESTING_ENGINE_STATE_ROOT=/var/lib/backtesting-engine/state
BACKTESTING_ENGINE_SECRET_PATH=/run/backtesting-engine/credentials/runtime.env
